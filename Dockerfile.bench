FROM rust:1.75-slim

RUN apt-get update && apt-get install -y \
    python3 python3-pip curl wget git \
    && rm -rf /var/lib/apt/lists/*

RUN pip3 install rdflib requests

WORKDIR /janus
COPY . .

RUN cargo build --release \
    --example h1_latency_benchmark \
    --example h2_correctness_benchmark \
    --example h4_scalability_benchmark

ENTRYPOINT ["bash", "scripts/run_all_benchmarks.sh"]
